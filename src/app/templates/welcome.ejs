<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Planora</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9faf6;
            color: #191c1b;
            line-height: 1.6;
        }

        .wrapper {
            width: 100%;
            background-color: #f9faf6;
            padding: 40px 20px;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 2px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(25, 28, 27, 0.04);
            border: 1px solid #edeeeb;
        }

        .header {
            padding: 60px 40px 40px;
            text-align: left;
        }

        .brand {
            margin-bottom: 24px;
            display: block;
        }

        .header h1 {
            font-family: 'Newsreader', serif;
            font-size: 44px;
            line-height: 1.1;
            margin-bottom: 24px;
            color: #1a4d3c;
            font-weight: 500;
        }

        .content {
            padding: 0 40px 60px;
        }

        .greeting {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #191c1b;
        }

        .message {
            font-size: 16px;
            color: #404944;
            margin-bottom: 40px;
        }

        .feature-grid {
            margin-bottom: 40px;
        }

        .feature-item {
            padding: 24px;
            background-color: #f3f4f1;
            border-radius: 4px;
            border-left: 4px solid #1a4d3c;
            margin-bottom: 16px;
        }

        .feature-item h3 {
            font-family: 'Newsreader', serif;
            font-size: 20px;
            color: #1a4d3c;
            margin-bottom: 8px;
        }

        .feature-item p {
            font-size: 14px;
            color: #58685f;
        }

        .cta-container {
            text-align: left;
        }

        .cta-button {
            display: inline-block;
            background-color: #1a4d3c;
            color: #ffffff !important;
            padding: 18px 40px;
            border-radius: 100px;
            text-decoration: none;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .footer {
            background-color: #f3f4f1;
            padding: 40px;
            text-align: left;
            border-top: 1px solid #e2e3e0;
        }

        .footer-text {
            font-size: 11px;
            color: #707974;
            margin-bottom: 8px;
        }

        @media (max-width: 600px) {
            .header { padding: 40px 20px 20px; }
            .content { padding: 0 20px 40px; }
            .header h1 { font-size: 32px; }
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <a href="#" class="brand">
                    <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 25px; display: block;">
                </a>
                <h1>Welcome to the <br/>Planora Circle.</h1>
            </div>

            <div class="content">
                <div class="greeting">
                    Hey <%= name %>,
                </div>

                <p class="message">
                    We're thrilled to have you join our community! Your journey to curated, sophisticated experiences starts here. Explore, create, and experience the best moments.
                </p>

                <div class="feature-grid">
                    <div class="feature-item">
                        <h3>Discover Events</h3>
                        <p>Find extraordinary gatherings that match your taste.</p>
                    </div>
                    <div class="feature-item">
                        <h3>Organize with Ease</h3>
                        <p>Create and manage events with our powerful host dashboard.</p>
                    </div>
                </div>

                <div class="cta-container">
                    <a href="<%= dashboardUrl %>" class="cta-button">Explore Your Dashboard</a>
                </div>
            </div>

            <div class="footer">
                <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 20px; margin-bottom: 16px; opacity: 0.8;">
                <p class="footer-text">© 2026 Planora. The Digital Maître D’.</p>
                <p class="footer-text">This email was sent to <%= email %>. Designed for visionaries.</p>
            </div>
        </div>
    </div>
</body>
</html>
