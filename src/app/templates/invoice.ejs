<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Invoice</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9faf6;
            color: #191c1b;
            line-height: 1.6;
        }

        .wrapper {
            width: 100%;
            background-color: #f9faf6;
            padding: 40px 20px;
        }

        .container {
            max-width: 650px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 2px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(25, 28, 27, 0.04);
            border: 1px solid #edeeeb;
        }

        .header {
            padding: 60px 40px 40px;
            text-align: left;
        }

        .brand {
            margin-bottom: 24px;
            display: block;
        }

        .header h1 {
            font-family: 'Newsreader', serif;
            font-size: 36px;
            line-height: 1.1;
            margin-bottom: 8px;
            color: #1a4d3c;
            font-weight: 500;
        }

        .header p {
            font-size: 14px;
            color: #58685f;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .content {
            padding: 0 40px 60px;
        }

        .greeting {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #191c1b;
        }

        .info-box {
            background-color: #f3f4f1;
            padding: 24px;
            border-radius: 4px;
            margin-bottom: 40px;
            border-left: 4px solid #1a4d3c;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .info-label {
            color: #58685f;
            font-weight: 500;
        }

        .info-value {
            color: #191c1b;
            font-weight: 600;
            text-align: right;
        }

        .section-title {
            font-family: 'Newsreader', serif;
            font-size: 20px;
            color: #1a4d3c;
            margin-bottom: 16px;
            border-bottom: 1px solid #edeeeb;
            padding-bottom: 8px;
        }

        .amount-box {
            background-color: #1a4d3c;
            color: #ffffff;
            padding: 32px;
            border-radius: 4px;
            text-align: center;
            margin-bottom: 40px;
        }

        .amount-label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 8px;
            opacity: 0.8;
        }

        .amount-value {
            font-family: 'Newsreader', serif;
            font-size: 40px;
            font-weight: 700;
        }

        .cta-container {
            text-align: center;
            margin-bottom: 40px;
        }

        .cta-button {
            display: inline-block;
            border: 1px solid #1a4d3c;
            color: #1a4d3c !important;
            padding: 14px 32px;
            border-radius: 100px;
            text-decoration: none;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .footer {
            background-color: #f3f4f1;
            padding: 40px;
            text-align: left;
            border-top: 1px solid #e2e3e0;
        }

        .footer-text {
            font-size: 11px;
            color: #707974;
            margin-bottom: 8px;
        }

        @media (max-width: 600px) {
            .header { padding: 40px 20px 20px; }
            .content { padding: 0 20px 40px; }
            .header h1 { font-size: 28px; }
            .info-row { flex-direction: column; }
            .info-value { text-align: left; margin-top: 4px; }
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <a href="#" class="brand">
                    <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 25px; display: block;">
                </a>
                <h1>Invoice Summary</h1>
                <p>Payment Confirmation Receipt</p>
            </div>

            <div class="content">
                <div class="greeting">
                    Dear <%= attendeeName %>,
                </div>

                <p class="message" style="margin-bottom: 24px;">
                    Your payment for the event registration has been successfully processed. Thank you for choosing Planora.
                </p>

                <div class="info-box">
                    <div class="info-row">
                        <span class="info-label">Invoice ID:</span>
                        <span class="info-value"><%= invoiceId %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Transaction ID:</span>
                        <span class="info-value"><%= transactionId %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Payment Date:</span>
                        <span class="info-value"><%= paymentDate %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Status:</span>
                        <span class="info-value" style="color: #1a4d3c;">✓ Confirmed Paid</span>
                    </div>
                </div>

                <div class="section-title">Event Reservation</div>
                <div style="margin-bottom: 40px;">
                    <p style="font-weight: 700; color: #1a4d3c; font-size: 18px;"><%= eventTitle %></p>
                    <p style="color: #58685f; font-size: 14px;"><%= eventDate %></p>
                </div>

                <div class="amount-box">
                    <div class="amount-label">Total Amount Paid</div>
                    <div class="amount-value"><%= amount.toFixed(2) %> <%= currency.toUpperCase() %></div>
                </div>

                <% if (invoiceUrl) { %>
                <div class="cta-container">
                    <a href="<%= invoiceUrl %>" class="cta-button">Download PDF Invoice</a>
                </div>
                <% } %>
            </div>

            <div class="footer">
                <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 20px; margin-bottom: 16px; opacity: 0.8;">
                <p class="footer-text">© 2026 Planora. The Digital Maître D’.</p>
                <p class="footer-text">This is an automatically generated receipt. Please do not reply.</p>
            </div>
        </div>
    </div>
</body>
</html>
