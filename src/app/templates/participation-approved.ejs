<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Great News! Your Request was Approved</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #f9faf6;
            color: #191c1b;
            line-height: 1.6;
        }

        .wrapper {
            width: 100%;
            background-color: #f9faf6;
            padding: 40px 20px;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 2px; /* Minimalist sharp corners as per design */
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(25, 28, 27, 0.04);
            border: 1px solid #edeeeb;
        }

        .header {
            padding: 60px 40px 40px;
            text-align: left;
        }

        .brand {
            font-family: 'Newsreader', serif;
            font-size: 24px;
            font-weight: 700;
            color: #1a4d3c;
            margin-bottom: 40px;
            display: block;
            text-decoration: none;
        }

        .header h1 {
            font-family: 'Newsreader', serif;
            font-size: 44px;
            line-height: 1.1;
            margin-bottom: 24px;
            color: #1a4d3c;
            font-weight: 500;
        }

        .content {
            padding: 0 40px 60px;
        }

        .greeting {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #191c1b;
        }

        .message {
            font-size: 16px;
            color: #404944;
            margin-bottom: 40px;
        }

        .event-card {
            background-color: #f3f4f1;
            padding: 24px;
            border-radius: 4px;
            margin-bottom: 40px;
            border-left: 4px solid #1a4d3c;
        }

        .event-card h2 {
            font-family: 'Newsreader', serif;
            font-size: 22px;
            color: #1a4d3c;
            margin-bottom: 8px;
        }

        .event-info {
            font-size: 14px;
            color: #58685f;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
        }

        .cta-container {
            text-align: left;
        }

        .cta-button {
            display: inline-block;
            background-color: #1a4d3c;
            color: #ffffff !important;
            padding: 18px 40px;
            border-radius: 100px;
            text-decoration: none;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: opacity 0.2s;
        }

        .footer {
            background-color: #f3f4f1;
            padding: 40px;
            text-align: left;
            border-top: 1px solid #e2e3e0;
        }

        .footer-text {
            font-size: 12px;
            color: #707974;
            margin-bottom: 4px;
        }

        @media (max-width: 600px) {
            .header { padding: 40px 20px 20px; }
            .content { padding: 0 20px 40px; }
            .header h1 { font-size: 32px; }
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <!-- Header -->
            <div class="header">
                <a href="#" class="brand">
                    <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 25px; display: block;">
                </a>
                <h1>A Place has been <br/>Reserved for You.</h1>
            </div>

            <!-- Content -->
            <div class="content">
                <div class="greeting">
                    Dear <%= participantName %>,
                </div>

                <p class="message">
                    We are pleased to inform you that <strong><%= organizerName %></strong> has accepted your request to join their private event. Your presence is cordially invited.
                </p>

                <div class="event-card">
                    <span class="event-info">Confirmed Attendance</span>
                    <h2><%= eventName %></h2>
                </div>

                <div class="cta-container">
                    <a href="<%= dashboardUrl %>" class="cta-button">Visit Your Dashboard</a>
                </div>
            </div>

            <!-- Footer -->
            <div class="footer">
                <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 24px; margin-bottom: 16px; opacity: 0.8;">
                <p class="footer-text">© 2026 Planora. The Digital Maître D’.</p>
                <p class="footer-text">Designed for those who value time, taste, and seamless execution.</p>
            </div>
        </div>
    </div>
</body>
</html>
