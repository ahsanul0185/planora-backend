<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verification Code</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9faf6;
            color: #191c1b;
            line-height: 1.6;
        }

        .wrapper {
            width: 100%;
            background-color: #f9faf6;
            padding: 40px 20px;
        }

        .container {
            max-width: 500px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 2px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(25, 28, 27, 0.04);
            border: 1px solid #edeeeb;
        }

        .header {
            padding: 60px 40px 40px;
            text-align: left;
        }

        .brand {
            margin-bottom: 24px;
            display: block;
        }

        .header h1 {
            font-family: 'Newsreader', serif;
            font-size: 36px;
            line-height: 1.1;
            margin-bottom: 8px;
            color: #1a4d3c;
            font-weight: 500;
        }

        .content {
            padding: 0 40px 60px;
        }

        .greeting {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #191c1b;
        }

        .message {
            font-size: 14px;
            color: #404944;
            margin-bottom: 40px;
        }

        .otp-box {
            background-color: #f3f4f1;
            padding: 32px;
            border-radius: 4px;
            text-align: center;
            margin-bottom: 40px;
            border: 1px dashed #1a4d3c;
        }

        .otp-code {
            font-family: 'Newsreader', serif;
            font-size: 48px;
            font-weight: 700;
            color: #1a4d3c;
            letter-spacing: 0.2em;
        }

        .footer {
            background-color: #f3f4f1;
            padding: 40px;
            text-align: left;
            border-top: 1px solid #e2e3e0;
        }

        .footer-text {
            font-size: 11px;
            color: #707974;
            margin-bottom: 8px;
        }

        @media (max-width: 600px) {
            .header { padding: 40px 20px 20px; }
            .content { padding: 0 20px 40px; }
            .header h1 { font-size: 28px; }
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <a href="#" class="brand">
                    <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 25px; display: block;">
                </a>
                <h1>Secure Access</h1>
            </div>

            <div class="content">
                <div class="greeting">
                    Hello <%= name %>,
                </div>

                <p class="message" style="margin-bottom: 24px;">
                    Your verification code for Planora is provided below. For your security, this code will expire in 2 minutes.
                </p>

                <div class="otp-box">
                    <div class="otp-code"><%= otp %></div>
                </div>

                <p style="font-size: 12px; color: #707974; text-align: center;">
                    If you did not request this code, please ignore this email or contact support.
                </p>
            </div>

            <div class="footer">
                <img src="https://res.cloudinary.com/dw8bzha3e/image/upload/v1774958156/planora-logo_n5dfou.png" alt="Planora Logo" style="height: 20px; margin-bottom: 16px; opacity: 0.8;">
                <p class="footer-text">© 2026 Planora. The Digital Maître D’.</p>
                <p class="footer-text">Plan. Attend. Experience. Designed for visionaries.</p>
            </div>
        </div>
    </div>
</body>
</html>